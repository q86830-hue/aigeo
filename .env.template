# ============================================
# 独立版环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# LLM API 配置 (必填)
# 支持 DeepSeek 或 OpenAI 兼容的 API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 或使用 OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# API 基础URL (可选，默认使用 DeepSeek)
API_BASE_URL=https://api.deepseek.com

# 搜索 API 配置 (可选，用于热点搜索工具)
# 支持 Serper.dev (推荐) 或 Google Custom Search
SERPER_API_KEY=your_serper_api_key_here
# 或
# SEARCH_API_KEY=your_search_api_key_here
# SEARCH_ENGINE_ID=your_search_engine_id_here

# 输出目录 (可选，默认 ./output)
OUTPUT_DIR=./output

# 工作空间路径 (可选)
WORKSPACE_PATH=G:\WZSPG

# ============================================
# 可选: PostgreSQL 数据库配置 (用于持久化会话)
# ============================================
# PGDATABASE_URL=postgresql://user:password@localhost:5432/dbname
